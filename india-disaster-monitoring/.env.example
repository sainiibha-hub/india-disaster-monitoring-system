# Copy this file to .env and fill in your own values.
# main.py / config.py loads this automatically via python-dotenv.

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=india_disaster_monitoring

# --- OpenWeatherMap (rainfall / temperature / humidity) ---
# Free key: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# --- Earthquake settings (USGS API needs no key) ---
EARTHQUAKE_MIN_MAGNITUDE=5.0
EARTHQUAKE_LOOKBACK_DAYS=30

# --- Optional real data feeds ---
# Leave blank to use the built-in realistic simulator for these two feeds
# (see core/flood.py and core/cyclone.py for details on why, and how to
# plug in a real feed once you have access to one).
FLOOD_API_URL=
CYCLONE_API_URL=

# --- Misc thresholds ---
HEAVY_RAINFALL_THRESHOLD_MM=65

# --- Scheduler ---
DAILY_RUN_TIME=06:00

# --- Flask dashboard ---
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False
